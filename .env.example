# Copy to .env (never commit .env) and adjust as needed.
# Documented in docs/architecture.md §5.

# ---- Database (Postgres container) ----
POSTGRES_DB=tickets
POSTGRES_USER=tickets
POSTGRES_PASSWORD=change-me

# ---- Backend (Spring Boot) ----
# Datasource points at the 'db' service on the compose network.
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/tickets
SPRING_DATASOURCE_USERNAME=tickets
SPRING_DATASOURCE_PASSWORD=change-me

# Session lifetimes (see AMB-7 / A-3): absolute cap + idle/sliding timeout.
APP_SESSION_TIMEOUT_IDLE=30m
APP_SESSION_TIMEOUT_ABSOLUTE=8h

# Email verification token TTL (FR-A8).
APP_VERIFICATION_TOKEN_TTL=24h

# Public base URL used to build verification links in emails (FR-A6).
APP_BASE_URL=http://localhost:8081

# ---- SMTP ----
# Defaults target the dockerized Mailpit service (dev/test).
# To use the real relay, set SMTP_HOST=relay1.dataart.com (+ port/credentials) — no code change.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@tickets.local
